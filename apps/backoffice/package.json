{
  "name": "serreche-parapente-backoffice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- prisma generate && dotenv -e .env.local -- next dev",
    "build": "dotenv -e .env.local -- prisma generate && dotenv -e .env.local -- next build",
    "vercel-build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:check": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint:check && pnpm typecheck",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "seed:admin": "dotenv -e .env.local -- tsx prisma/seed-admin.ts",
    "seed:mock": "dotenv -e .env.local -- tsx prisma/seed-mock.ts",
    "db:reset": "dotenv -e .env.local -- tsx prisma/reset-db-keep-essentials.ts",
    "migrate:from-old": "dotenv -e .env.migration -- tsx prisma/migrate-from-old.ts",
    "test:email": "tsx src/scripts/test-email.ts",
    "test:stage-reminder": "dotenv -e .env.local -- tsx src/scripts/test-stage-reminder.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "0.3.0",
    "@hookform/resolvers": "^3.10.0",
    "@hugeicons/core-free-icons": "^4.0.0",
