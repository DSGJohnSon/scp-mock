# =============================================================================
# apps/backoffice — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Supabase)
# https://supabase.com/dashboard/project/<project-id>/settings/database
#
# DATABASE_URL: pooled connection (port 6543, pgbouncer=true) — used at runtime
# DIRECT_URL:   direct connection (port 5432) — used only by Prisma Migrate
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# App URL (must match the actual deployment URL in production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# better-auth
# https://www.better-auth.com/docs/installation
#
# BETTER_AUTH_SECRET: random 32-byte string
#   generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Public API key (shared secret with apps/front)
# Must match NEXT_PUBLIC_API_KEY in apps/front/.env.local
#   generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
PUBLIC_API_KEY=""

# -----------------------------------------------------------------------------
# Stripe
# https://dashboard.stripe.com/apikeys
#
# Use TEST keys locally (sk_test_...).
# NEVER put live keys (sk_live_...) outside the Vercel Production environment.
#
# STRIPE_WEBHOOK_SECRET: run locally with the Stripe CLI:
#   stripe listen --forward-to localhost:3001/api/webhooks/stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Resend (transactional email)
# https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains before deploying.
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Your App <noreply@yourdomain.com>"
ADMIN_EMAIL="admin@yourdomain.com"

# -----------------------------------------------------------------------------
# Brevo (SMS campaigns) — optional
# https://app.brevo.com/settings/keys/api
#
# Set SMS_SIMULATION=true in dev to log SMS to console instead of sending them.
# -----------------------------------------------------------------------------
BREVO_API_KEY=""
BREVO_SENDER_NAME=""
SMS_SIMULATION=true
