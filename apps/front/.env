# =============================================================================
# apps/front — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backoffice API
# URL of the running backoffice (localhost:3001 in dev, Vercel URL in prod).
# NEXT_PUBLIC_API_KEY must match PUBLIC_API_KEY in apps/backoffice/.env.local.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BACKOFFICE_URL="http://localhost:3001"
NEXT_PUBLIC_API_KEY="4a473a5726b60f66e2e064da24827b622dd07f8a1db61300bb578ff505f8966e"

# -----------------------------------------------------------------------------
# Stripe (publishable key — safe to expose client-side)
# https://dashboard.stripe.com/apikeys
# Use the TEST publishable key locally (pk_test_...).
# -----------------------------------------------------------------------------
