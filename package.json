{
  "name": "serreche-chevalier-parapente",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=serreche-parapente-backoffice",
    "db:migrate": "turbo run db:migrate --filter=serreche-parapente-backoffice",
    "db:studio": "turbo run db:studio --filter=serreche-parapente-backoffice",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.5.4"
  },
  "pnpm": {
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
},
  "simple-git-hooks": {},
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
